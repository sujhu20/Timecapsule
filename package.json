{
  "name": "time-capsule",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:critical": "export DATABASE_URL='file:./test.db' && npx prisma db push --skip-generate && jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "export DATABASE_URL='file:./test.db' && npx prisma db push --skip-generate && jest --ci --coverage --maxWorkers=2",
    "prepare-deploy": "node scripts/prepare-deploy.js",
    "generate-icons": "node scripts/generate-pwa-icons.js",
    "deploy": "npm run build && vercel",
    "deploy:prod": "npm run build && vercel --prod",
    "pwa:build": "npm run build",
    "android:setup": "npm i @capacitor/core @capacitor/android && npx cap init TimeCapsule \"TimeCapsule\" --web-dir=.next/static",
    "android:build": "npm run build && npx cap add android && npx cap copy",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
