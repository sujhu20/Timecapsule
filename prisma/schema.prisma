generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String? // Hashed password for credentials auth
  image         String? // For OAuth profile images
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Notification preferences
  emailNotifications Boolean @default(true)
  unlockReminders    Boolean @default(true)
  weeklyDigest       Boolean @default(false)
  marketingEmails    Boolean @default(false)

  capsules            Capsule[]
  auditLogs           AuditLog[]
  comments            Comment[]
  likes               Like[]
  followers           Follows[]           @relation("following")
  following           Follows[]           @relation("follower")
  verificationTokens  VerificationToken[]

  // Performance index for login queries
  @@index([email])
}

model Capsule {
  id         String   @id @default(uuid())
  title      String
  content    String // Encrypted content
  createdAt  DateTime @default(now())
  unlockTime DateTime
  isLocked   Boolean  @default(true)
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id])

  // Digital Trustee / Legacy fields
  recipientName  String?
  recipientEmail String?

  // Social fields
  likes    Like[]
  comments Comment[]
  privacy  String    @default("private") // public, private

  auditLogs AuditLog[]

  // Performance indexes
  @@index([ownerId, createdAt])
  @@index([unlockTime, isLocked])
  @@index([privacy])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  // Performance index for comment threads
  @@index([capsuleId, createdAt])
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  @@unique([userId, capsuleId])
  // Performance index for like counts
  @@index([capsuleId])
}

model Follows {
  follower    User   @relation("follower", fields: [followerId], references: [id])
  followerId  String
  following   User   @relation("following", fields: [followingId], references: [id])
  followingId String

  @@id([followerId, followingId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  capsuleId String?
  userId    String?
  capsule   Capsule? @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  details   String?

  // Performance indexes for audit log queries
  @@index([userId, timestamp])
  @@index([capsuleId, timestamp])
  @@index([action, timestamp])
}

/// Used for email address verification (credentials sign-up flow)
model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique // SHA-256 hashed token
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}
