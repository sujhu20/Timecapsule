generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  email              String              @unique
  name               String?
  password           String?
  image              String?
  emailVerified      DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  emailNotifications Boolean             @default(true)
  unlockReminders    Boolean             @default(true)
  weeklyDigest       Boolean             @default(false)
  marketingEmails    Boolean             @default(false)
  auditLogs          AuditLog[]
  capsules           Capsule[]
  comments           Comment[]
  following          Follows[]           @relation("follower")
  followers          Follows[]           @relation("following")
  likes              Like[]
  verificationTokens VerificationToken[]

  @@index([email])
}

model Capsule {
  id             String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  title          String
  content        String
  createdAt      DateTime   @default(now())
  unlockTime     DateTime
  isLocked       Boolean    @default(true)
  ownerId        String
  recipientName  String?
  recipientEmail String?
  privacy        String     @default("private")
  auditLogs      AuditLog[]
  owner          User       @relation(fields: [ownerId], references: [id])
  comments       Comment[]
  likes          Like[]

  @@index([ownerId, createdAt])
  @@index([unlockTime, isLocked])
  @@index([privacy])
}

model Comment {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  userId    String
  capsuleId String
  capsule   Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([capsuleId, createdAt])
}

model Like {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  createdAt DateTime @default(now())
  userId    String
  capsuleId String
  capsule   Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, capsuleId])
  @@index([capsuleId])
}

model Follows {
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id])
  following   User   @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model AuditLog {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  action    String
  capsuleId String?
  userId    String?
  timestamp DateTime @default(now())
  details   String?
  capsule   Capsule? @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([capsuleId, timestamp])
  @@index([action, timestamp])
}

/// Used for email address verification (credentials sign-up flow)
model VerificationToken {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
