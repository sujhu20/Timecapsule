# Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Example: postgresql://postgres:password@localhost:5432/timecapsule?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/timecapsule"

# ============================================
# AUTHENTICATION
# ============================================
# NextAuth secret - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here-min-32-chars"

# Your application URL
NEXTAUTH_URL="http://localhost:3000"

# ============================================
# ENCRYPTION (CRITICAL)
# ============================================
# 32-byte encryption key (44 characters in base64)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="your-encryption-key-here-44-chars-base64"

# ============================================
# OAUTH PROVIDERS (Optional)
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# MONITORING (Optional)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=""

# ============================================
# CRON JOBS (Production)
# ============================================
# Secret for authenticating cron job requests
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here-min-32-chars"

# ============================================
# EMAIL (Optional)
# ============================================
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_SECURE="true"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="notifications@timecapsul.app"

# ============================================
# DEVELOPMENT
# ============================================
NODE_ENV="development"
